# RISC V2.0 Master Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Replace with your actual local IP for mobile sync
HOST_IP=127.0.0.1

# AI API Keys (get from Google AI Studio)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# System Ports
BRAIN_PORT=8001
REPORTER_PORT=8002
DASHBOARD_PORT=3000

# Database
DB_PASSWORD=your_secure_password_here
