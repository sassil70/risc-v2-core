# ═══════════════════════════════════════════════════
# RISC V2 Brain Cluster — Production Environment
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in production values.
# For Cloud Run, set these via Secret Manager / env vars.

# ── Database (Cloud SQL) ──
DB_HOST=/cloudsql/<PROJECT_ID>:<REGION>:<INSTANCE_NAME>
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=<GENERATE_STRONG_PASSWORD>
DB_NAME=risc_v2_db

# ── Security ──
# Generate with: openssl rand -hex 64
SECRET_KEY=<GENERATE_WITH_OPENSSL_RAND_HEX_64>

# ── CORS Origins (comma-separated) ──
# Example: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com

# ── Google AI ──
GEMINI_API_KEY=<FROM_GOOGLE_CLOUD_CONSOLE>
GOOGLE_API_KEY=<FROM_GOOGLE_CLOUD_CONSOLE>
GOOGLE_CLOUD_PROJECT=smart-inspection-2025

# ── AI Model ──
GEMINI_MODEL_KEY=gemini-3-flash-preview

# ── Server (Cloud Run auto-sets PORT) ──
PORT=8000
